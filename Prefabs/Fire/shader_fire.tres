code = "shader_type canvas_item;
render_mode blend_mix, unshaded;

uniform vec2 Scale = vec2(1.000000, 1.000000);
uniform vec2 Speed;
uniform sampler2D Texture_MAIN : source_color, repeat_enable;
uniform float intensity = 1.0;
uniform sampler2D Texture_ADD : source_color;
uniform sampler2D Texture_MULT : source_color;
uniform sampler2D Texture_SUB : source_color;
uniform sampler2D Texture_COLOR : source_color;



void fragment() {
// Vector2Parameter:17
	vec2 n_out17p0 = Scale;


// UVFunc:16
	vec2 n_in16p2 = vec2(0.00000, 0.00000);
	vec2 n_out16p0 = (UV - n_in16p2) * n_out17p0 + n_in16p2;


// Input:13
	float n_out13p0 = TIME;


// Vector2Parameter:14
	vec2 n_out14p0 = Speed;


// VectorOp:15
	vec3 n_out15p0 = vec3(n_out13p0) * vec3(n_out14p0, 0.0);


// UVFunc:12
	vec2 n_in12p1 = vec2(1.00000, 1.00000);
	vec2 n_out12p0 = vec2(n_out15p0.xy) * n_in12p1 + n_out16p0;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(Texture_MAIN, n_out12p0);
	float n_out3p1 = n_out3p0.r;


// Input:22
	vec2 n_out22p0 = UV;


// FloatParameter:24
	float n_out24p0 = intensity;


// UVFunc:23
	vec2 n_in23p2 = vec2(0.00000, 0.00000);
	vec2 n_out23p0 = (n_out22p0 - n_in23p2) * vec2(n_out24p0) + n_in23p2;


	vec4 n_out5p0;
// Texture2D:5
	n_out5p0 = texture(Texture_ADD, n_out23p0);
	float n_out5p1 = n_out5p0.r;


// FloatOp:18
	float n_out18p0 = n_out3p1 + n_out5p1;


	vec4 n_out7p0;
// Texture2D:7
	n_out7p0 = texture(Texture_MULT, UV);
	float n_out7p1 = n_out7p0.r;


// FloatOp:19
	float n_out19p0 = n_out18p0 * n_out7p1;


	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(Texture_SUB, UV);
	float n_out8p1 = n_out8p0.r;


// FloatOp:20
	float n_out20p0 = n_out19p0 - n_out8p1;


// Clamp:21
	float n_in21p1 = 0.00000;
	float n_in21p2 = 1.00000;
	float n_out21p0 = clamp(n_out20p0, n_in21p1, n_in21p2);


	vec4 n_out10p0;
// Texture2D:10
	n_out10p0 = texture(Texture_COLOR, vec2(n_out21p0));
	float n_out10p4 = n_out10p0.a;


// Output:0
	COLOR.rgb = vec3(n_out10p0.xyz);
	COLOR.a = n_out10p4;


}
